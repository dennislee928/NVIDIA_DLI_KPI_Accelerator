{
  "manifest_version": 3,
  "name": "NVIDIA DLI KPI Accelerator",
  "version": "1.1",
  "description": "NVIDIA DLI 課程自動化測試工具 (v1.1: 包含進度追蹤與狀態反饋)",
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://learn.nvidia.com/*",
    "https://learn.learn.nvidia.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "DLI Accelerator"
  },
  "content_scripts": [
    {
      "matches": ["https://learn.nvidia.com/courses/course*"],
      "js": ["content.js"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
